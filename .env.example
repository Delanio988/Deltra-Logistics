# Copy this file to .env.local and fill in real values there. .env.local (and
# every .env* variant) is already git-ignored — never commit real secrets.

# ---- Supabase (DB + Auth + Storage) ----
NEXT_PUBLIC_SUPABASE_URL=                # Project URL — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Anon/public key — RLS-enforced, safe client-side
SUPABASE_SERVICE_ROLE_KEY=               # SERVER-ONLY. Bypasses RLS — never send to the client.

# ---- App ----
NEXT_PUBLIC_SITE_URL=                    # Canonical production URL (email links, OG metadata)

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=                              # e.g. "Deltra Logistics <no-reply@deltralogistics.com>"

# ---- SMS / WhatsApp (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=                  # Only if WhatsApp notifications are enabled

# ---- Payments (Fygaro) ----
# FYGARO_PAYMENT_BUTTON_URL is the actual integration point: create a Payment
# Button ("Fygaro Link") in the Fygaro dashboard and paste its URL here — a
# specific charge is requested by appending amount/reference query params to
# it (see lib/payments/fygaro.ts), no server-to-server "create session" call
# needed. Card/bank stay a "coming soon" placeholder in the UI until this is set.
FYGARO_PAYMENT_BUTTON_URL=
# The API credential you select in Fygaro under Settings > API Credentials to
# sign Hook (webhook) requests — set the same value as the button's Hook secret.
FYGARO_WEBHOOK_SECRET=
FYGARO_API_KEY=
FYGARO_MERCHANT_ID=
FYGARO_ENVIRONMENT=sandbox               # sandbox | live

# ---- Admin seeding ----
INITIAL_ADMIN_EMAIL=                     # Consumed once by the admin-seed script
INITIAL_ADMIN_PASSWORD=                  # Rotate immediately after first use

# ---- Cloudflare Turnstile (signup bot protection) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Rate limiting (Upstash Redis) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Error monitoring (Sentry) — optional ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                       # Source map upload only, CI-time
